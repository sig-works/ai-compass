---
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import Layout from '@/layouts/Layout.astro';
import aiNews from '@/data/ai-news.json';
import { SITE_NAME } from '@/lib/content';
import { navUrl } from '@/lib/navigation';
import { BookOpen, BrainCircuit, ExternalLink, Library, Newspaper, Route, ShieldCheck } from 'lucide-react';

const featuredRead = [
  {
    title: 'AI入門',
    description: 'AIでできること、苦手なこと、最初に試しやすい作業をまとめています。',
    href: '/articles/ai/ai-glossary/',
    icon: BookOpen
  },
  {
    title: 'LLMとは？',
    description: '言葉で頼むAIの仕組み、使う場所、頼み方の基本をまとめています。',
    href: '/articles/ai/llm-basics/',
    icon: BookOpen
  },
  {
    title: '安全なAI活用',
    description: '入力してよい情報、答えの確認、共有前チェックを扱います。',
    href: '/articles/ai/safety-guide/',
    icon: ShieldCheck
  }
];

const featuredUse = [
  {
    title: '用途別プロンプト集',
    description: '調査、実装、レビュー、文書化で使う依頼文の型を収録しています。',
    href: '/articles/ai/prompt-patterns/',
    icon: BrainCircuit
  },
  {
    title: 'AI用語集',
    description: '重要なAI用語を、意味、使われ方、具体例で確認します。',
    href: '/glossary/',
    icon: Library
  },
  {
    title: 'AIモデル選定ガイド',
    description: '主要モデルを用途に合わせて比較し、選び方の目安をまとめています。',
    href: '/llms/',
    icon: Route
  },
  {
    title: 'LLM紹介',
    description: '主要なLLMを特徴、得意な作業、注意点から確認します。',
    href: '/llms/catalog/',
    icon: BookOpen
  }
];

const tracks = [
  { label: 'AIの基本', icon: BookOpen },
  { label: 'LLMの使い方', icon: BrainCircuit },
  { label: 'プロンプト', icon: Library },
  { label: '安全な活用', icon: ShieldCheck }
];

const newsItems = aiNews.items.slice(0, 3);
const newsUpdatedAt = aiNews.generatedAt
  ? new Intl.DateTimeFormat('ja-JP', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit'
    }).format(new Date(aiNews.generatedAt))
  : '初回更新前';

function formatNewsDate(value: string) {
  if (!value) return '';

  return new Intl.DateTimeFormat('ja-JP', {
    month: '2-digit',
    day: '2-digit'
  }).format(new Date(value));
}
---

<Layout title={SITE_NAME} description="AIに関する日本語記事と実務ガイドをまとめた公開サイト。" currentPath="/">
	<section class="space-y-3">
		<Card>
			<CardHeader className="pb-2">
				<div class="flex flex-wrap items-center justify-between gap-2">
					<div>
						<CardTitle className="flex items-center gap-2 text-base">
							<Newspaper className="h-4 w-4 text-primary" />
							<a href={navUrl('/topics/')} class="text-foreground no-underline hover:text-primary">トピック</a>
						</CardTitle>
						<p class="mt-1 text-xs leading-5 text-muted-foreground">AI関連記事をまとめて確認</p>
					</div>
					<p class="text-[11px] leading-5 text-muted-foreground">更新: {newsUpdatedAt}</p>
				</div>
			</CardHeader>
			<CardContent className="grid gap-2">
				{newsItems.length > 0 ? (
					<>
						<div class="grid gap-1.5">
							{newsItems.map((item) => (
								<a href={item.url} target="_blank" rel="noreferrer" class="group rounded-md border border-border bg-background p-3 no-underline transition-colors hover:bg-muted">
									<div class="grid gap-3 sm:grid-cols-[12rem_minmax(0,1fr)] lg:grid-cols-[14rem_minmax(0,1fr)]">
										{item.imageUrl ? (
											<img src={item.imageUrl} alt="" loading="lazy" referrerpolicy="no-referrer" class="aspect-[16/10] w-full rounded-md border border-border object-cover" />
										) : null}
										<div class="min-w-0">
											<div class="flex flex-wrap items-center gap-2 text-[11px] text-muted-foreground">
												<Badge variant={item.sourceType === 'official' ? 'default' : 'secondary'} className="h-5 px-1.5 text-[10px]">
													{item.sourceType === 'official' ? '公式' : '記事'}
												</Badge>
												<span>{item.source}</span>
												{item.publishedAt && <span>{formatNewsDate(item.publishedAt)}</span>}
											</div>
											<h3 class="mt-2 line-clamp-2 text-base font-semibold leading-6 text-foreground">
												{item.title}
												<ExternalLink className="ml-1 inline h-3 w-3 text-muted-foreground transition-colors group-hover:text-primary" />
											</h3>
											{item.excerpt && <p class="mt-1 line-clamp-2 text-xs leading-5 text-muted-foreground sm:text-sm sm:leading-6">{item.excerpt}</p>}
										</div>
									</div>
								</a>
							))}
						</div>
					</>
				) : (
					<div class="rounded-md border border-dashed border-border bg-background p-3 text-sm leading-6 text-muted-foreground">
						日本語のAI関連記事は、GitHub Actionsまたは <code>npm run update:ai-news</code> で自動取得されます。
					</div>
				)}

				<div class="flex justify-end">
					<a href={navUrl('/topics/')} class="inline-flex h-8 items-center rounded-md border border-border bg-background px-3 text-xs font-medium text-foreground no-underline transition-colors hover:bg-muted">
						トピックをもっと見る
					</a>
				</div>
			</CardContent>
		</Card>

		<Card>
			<CardHeader className="pb-2">
				<CardTitle className="flex items-center gap-2 text-base">
					<BookOpen className="h-4 w-4 text-primary" />
					ガイド
				</CardTitle>
			</CardHeader>
			<CardContent className="grid gap-3">
				<div class="flex flex-wrap gap-1">
					{tracks.map((track) => (
						<Badge variant="outline" className="h-6 gap-1 px-2 text-[11px] sm:text-xs">
							<track.icon className="h-3.5 w-3.5 text-primary" />
							{track.label}
						</Badge>
					))}
				</div>
				<div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
					{[...featuredRead, ...featuredUse].map((item) => (
						<a href={navUrl(item.href)} class="rounded-md border border-border bg-card p-2.5 no-underline transition-colors hover:bg-muted sm:p-3">
							<div class="flex items-center gap-2">
								<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-border bg-secondary text-primary sm:h-8 sm:w-8">
									<item.icon className="h-4 w-4" />
								</span>
								<h3 class="text-sm font-semibold leading-5 text-foreground">{item.title}</h3>
							</div>
							<p class="mt-2 line-clamp-2 text-xs leading-5 text-muted-foreground sm:text-sm sm:leading-6">{item.description}</p>
						</a>
					))}
				</div>
			</CardContent>
		</Card>
	</section>
</Layout>
