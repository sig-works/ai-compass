---
import GlossaryExplorer from '@/components/common/GlossaryExplorer';
import Layout from '@/layouts/Layout.astro';
import { GLOSSARY_SECTIONS } from '@/lib/glossary';

const termCount = GLOSSARY_SECTIONS.reduce((sum, section) => sum + section.terms.length, 0);
---

<Layout title="AI用語集 | AI Compass" description="AIに関する重要な用語を日常的な言葉と具体例で確認できる用語集" currentPath="/glossary/">
	<section class="grid min-h-[calc(100dvh-7rem)] grid-rows-[auto_minmax(0,1fr)] gap-2 lg:h-[calc(100dvh-8.5rem)] lg:min-h-0 lg:gap-3 lg:overflow-hidden">
		<header class="hidden rounded-md border border-border bg-card px-3 py-2 shadow-sm sm:block sm:px-4 sm:py-3">
			<div class="flex flex-wrap items-center justify-between gap-2 sm:gap-3">
				<div class="min-w-0">
					<p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground">Glossary</p>
					<div class="mt-1 flex flex-wrap items-end gap-2">
						<h1 class="text-2xl font-semibold tracking-tight">AI用語集</h1>
						<span class="rounded-md border border-border bg-secondary px-2 py-1 text-xs font-medium text-secondary-foreground">
							{termCount}語
						</span>
					</div>
				</div>
				<p class="hidden max-w-2xl text-sm leading-6 text-muted-foreground sm:block">
					AIに関する重要な言葉を、初心者向けに分かりやすく整理します。英語や略語は別名と正式名称も合わせて確認できます。
				</p>
			</div>
		</header>

		<GlossaryExplorer client:load sections={GLOSSARY_SECTIONS} />
	</section>

	<details class="mt-3 rounded-md border border-border bg-card px-3 py-2 text-sm shadow-sm">
		<summary class="cursor-pointer font-semibold">全{termCount}語の静的本文</summary>
		<section class="mt-3 grid gap-4" aria-label="AI用語集の静的本文">
			<h2 class="sr-only">AI用語集 静的本文</h2>
			<p class="text-muted-foreground">このページの正本は {termCount} 語、{GLOSSARY_SECTIONS.length} カテゴリです。</p>
		{GLOSSARY_SECTIONS.map((section) => (
			<section id={`glossary-static-${section.id}`} class="grid gap-2">
				<h3 class="text-base font-semibold">{section.title}</h3>
				<p class="text-muted-foreground">{section.description}</p>
				<div class="grid gap-2 md:grid-cols-2 xl:grid-cols-3">
				{section.terms.map((term) => (
					<article id={`glossary-static-${term.id ?? term.term}`} class="rounded-md border border-border bg-background p-3">
						<h4 class="font-semibold">{term.term}</h4>
						{term.fullName && <p class="mt-1 text-xs text-muted-foreground">正式名称: {term.fullName}</p>}
						{term.aliases && term.aliases.length > 0 && <p class="mt-1 text-xs text-muted-foreground">別名: {term.aliases.join(' / ')}</p>}
						<p class="mt-2">要約: {term.plainSummary}</p>
						<p class="mt-2 text-muted-foreground">意味: {term.meaning}</p>
						<p class="mt-2 text-muted-foreground">注意点: {term.misconception}</p>
						<p class="mt-2 text-muted-foreground">AIでの使われ方: {term.usageInAi}</p>
						<ul class="mt-2 list-disc space-y-1 pl-5 text-muted-foreground">
							{term.workflow.map((step) => <li>{step}</li>)}
						</ul>
						<p class="mt-2 text-muted-foreground">具体例: {term.example}</p>
						<p class="mt-2 text-muted-foreground">関連用語: {term.relatedTerms.join(' / ')}</p>
					</article>
				))}
				</div>
			</section>
		))}
		</section>
	</details>
</Layout>
