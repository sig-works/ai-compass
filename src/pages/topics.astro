---
import { Badge } from '@/components/ui/badge';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import Layout from '@/layouts/Layout.astro';
import aiNews from '@/data/ai-news.json';
import { navUrl } from '@/lib/navigation';
import { ExternalLink, Newspaper, Sparkles } from 'lucide-react';

const title = 'トピック';
const description = '日本語のAI関連記事を、公式ブログと国内メディアのRSSから自動取得してまとめます。';
const items = aiNews.items;
const leadItem = items[0];
const subItems = items.slice(1, 4);
const listItems = items.slice(4);
const sourceSummary = aiNews.sources.map((source) => ({
  ...source,
  count: items.filter((item) => item.sourceId === source.id).length
}));

function formatDate(value: string) {
  if (!value) return '';

  return new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(new Date(value));
}
---

<Layout title={`${title} | AI Compass`} description={description} currentPath="/topics/">
	<section class="space-y-3">
		{leadItem ? (
			<section class="grid gap-3 xl:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.65fr)]">
				<a href={leadItem.url} target="_blank" rel="noreferrer" class="group rounded-md border border-border bg-card p-4 no-underline shadow-sm transition-colors hover:bg-muted sm:p-5">
					{leadItem.imageUrl && (
						<img src={leadItem.imageUrl} alt="" loading="lazy" referrerpolicy="no-referrer" class="mb-4 aspect-[16/7] w-full rounded-md border border-border object-cover" />
					)}
					<div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
						<Badge variant={leadItem.sourceType === 'official' ? 'default' : 'secondary'} className="h-6 text-[11px]">
							{leadItem.sourceType === 'official' ? '公式' : '記事'}
						</Badge>
						<span>{leadItem.source}</span>
						{leadItem.publishedAt && <span>{formatDate(leadItem.publishedAt)}</span>}
					</div>
					<h2 class="mt-3 text-xl font-semibold leading-8 text-foreground sm:text-2xl sm:leading-9">
						{leadItem.title}
						<ExternalLink className="ml-1 inline h-4 w-4 text-muted-foreground transition-colors group-hover:text-primary" />
					</h2>
					{leadItem.excerpt && <p class="mt-3 text-sm leading-7 text-muted-foreground sm:text-base sm:leading-8">{leadItem.excerpt}</p>}
				</a>

				<div class="grid gap-2">
					{subItems.map((item) => (
						<a href={item.url} target="_blank" rel="noreferrer" class="group rounded-md border border-border bg-card p-3 no-underline transition-colors hover:bg-muted">
							{item.imageUrl && (
								<img src={item.imageUrl} alt="" loading="lazy" referrerpolicy="no-referrer" class="mb-2 aspect-[16/7] w-full rounded-md border border-border object-cover" />
							)}
							<div class="flex flex-wrap items-center gap-2 text-[11px] text-muted-foreground">
								<Badge variant={item.sourceType === 'official' ? 'default' : 'secondary'} className="h-5 px-1.5 text-[10px]">
									{item.sourceType === 'official' ? '公式' : '記事'}
								</Badge>
								<span>{item.source}</span>
								{item.publishedAt && <span>{formatDate(item.publishedAt)}</span>}
							</div>
							<h3 class="mt-2 line-clamp-2 text-sm font-semibold leading-5 text-foreground">
								{item.title}
								<ExternalLink className="ml-1 inline h-3 w-3 text-muted-foreground transition-colors group-hover:text-primary" />
							</h3>
						</a>
					))}
				</div>
			</section>
		) : (
			<Card>
				<CardContent className="p-4 text-sm leading-6 text-muted-foreground">
					日本語のAI関連記事は、GitHub Actionsまたは <code>npm run update:ai-news</code> で自動取得されます。
				</CardContent>
			</Card>
		)}

		<div class="grid gap-3 xl:grid-cols-[minmax(0,1fr)_18rem]">
			<Card>
				<CardHeader className="pb-2">
					<div class="flex flex-wrap items-center justify-between gap-2">
						<CardTitle className="flex items-center gap-2 text-base">
							<Newspaper className="h-4 w-4 text-primary" />
							新着一覧
						</CardTitle>
						<Badge variant="outline" className="h-6 text-[11px]">{items.length}件</Badge>
					</div>
				</CardHeader>
				<CardContent className="grid gap-2">
					{listItems.length > 0 ? (
						listItems.map((item) => (
							<a href={item.url} target="_blank" rel="noreferrer" class="group rounded-md border border-border bg-background p-3 no-underline transition-colors hover:bg-muted">
								<div class={['grid gap-3', item.imageUrl ? 'sm:grid-cols-[8.5rem_minmax(0,1fr)]' : ''].filter(Boolean).join(' ')}>
									{item.imageUrl ? (
										<img src={item.imageUrl} alt="" loading="lazy" referrerpolicy="no-referrer" class="aspect-[16/10] w-full rounded-md border border-border object-cover" />
									) : null}
									<div class="min-w-0">
										<div class="flex flex-wrap items-center gap-2 text-[11px] text-muted-foreground">
											<Badge variant={item.sourceType === 'official' ? 'default' : 'secondary'} className="h-5 px-1.5 text-[10px]">
												{item.sourceType === 'official' ? '公式' : '記事'}
											</Badge>
											<span>{item.source}</span>
											{item.publishedAt && <span>{formatDate(item.publishedAt)}</span>}
										</div>
										<h3 class="mt-2 text-sm font-semibold leading-5 text-foreground">
											{item.title}
											<ExternalLink className="ml-1 inline h-3 w-3 text-muted-foreground transition-colors group-hover:text-primary" />
										</h3>
										{item.excerpt && <p class="mt-1 line-clamp-2 text-xs leading-5 text-muted-foreground sm:text-sm sm:leading-6">{item.excerpt}</p>}
									</div>
								</div>
							</a>
						))
					) : (
						<p class="rounded-md border border-dashed border-border bg-background p-3 text-sm leading-6 text-muted-foreground">追加の記事はまだありません。</p>
					)}
				</CardContent>
			</Card>

			<aside class="space-y-3">
				<Card>
					<CardHeader className="pb-2">
						<CardTitle className="flex items-center gap-2 text-base">
							<Sparkles className="h-4 w-4 text-primary" />
							取得元
						</CardTitle>
					</CardHeader>
					<CardContent className="grid gap-2">
						{sourceSummary.map((source) => (
							<a href={source.url} target="_blank" rel="noreferrer" class="rounded-md border border-border bg-background p-3 no-underline transition-colors hover:bg-muted">
								<div class="flex items-center justify-between gap-2">
									<span class="text-sm font-semibold text-foreground">{source.name}</span>
									<Badge variant={source.type === 'official' ? 'default' : 'secondary'} className="h-5 px-1.5 text-[10px]">
										{source.type === 'official' ? '公式' : '記事'}
									</Badge>
								</div>
								<p class="mt-1 text-xs leading-5 text-muted-foreground">{source.count}件表示中</p>
							</a>
						))}
					</CardContent>
				</Card>
			</aside>
		</div>
	</section>
</Layout>
