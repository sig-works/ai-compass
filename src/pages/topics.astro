---
import { Badge } from '@/components/ui/badge';
import Layout from '@/layouts/Layout.astro';
import aiNews from '@/data/ai-news.json';
import { Newspaper } from 'lucide-react';

const title = 'AI News';
const description = 'OpenAI、Anthropic、Google、Copilot、国内AIニュースを、国内・海外で切り替えて確認できるニュースリーダー。';
const regions = aiNews.regions ?? [
  { id: 'domestic', label: '国内', description: '日本語公式情報と国内AIメディアを中心に確認します。' },
  { id: 'global', label: '海外', description: '海外の一次ソース・公式系ニュースを中心に確認します。' }
];
const categories = aiNews.categories ?? [
  { id: 'ai-news', label: '国内ニュース', description: '国内向けの日本語AIニュースと日本語公式情報。' },
  { id: 'tech-articles', label: '技術記事', description: '実装者向けの日本語AI技術記事。' },
  { id: 'official', label: '公式', description: 'OpenAI、Anthropic、Google、Copilot 関連の公式・準公式ニュース。' }
];
const items = aiNews.items ?? [];
const defaultRegion = regions.some((region) => region.id === 'domestic') ? 'domestic' : regions[0]?.id ?? 'global';
const defaultCategory = categories[0]?.id ?? 'openai';
const updatedAt = aiNews.generatedAt
  ? new Intl.DateTimeFormat('ja-JP', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit'
    }).format(new Date(aiNews.generatedAt))
  : '未更新';

function formatDate(value: string) {
  if (!value) return '';

  return new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(new Date(value));
}

function panelId(regionId: string, categoryId: string) {
  return `${regionId}:${categoryId}`;
}

function itemCount(regionId: string, categoryId: string) {
  return items.filter((item) => item.regionId === regionId && item.categoryId === categoryId).length;
}

function sourceTypeLabel(value: string) {
  if (value === 'official') return '公式';
  if (value === 'domestic-media') return '国内メディア';
  return '準公式';
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fallbackImage = `${base}/images/news-fallback.png`;
function resolveImageUrl(url: string): string {
  if (url.startsWith('/images/')) return `${base}${url}`;
  return url;
}

const tabEntries = categories
  .map((category) => {
    const domesticCount = itemCount('domestic', category.id);
    const globalCount = itemCount('global', category.id);
    if (domesticCount > 0) return { category, regionId: 'domestic', count: domesticCount };
    if (globalCount > 0) return { category, regionId: 'global', count: globalCount };
    return null;
  })
  .filter((item): item is NonNullable<typeof item> => item !== null);
const initialTab = tabEntries[0] ?? { category: categories[0], regionId: defaultRegion, count: 0 };
const initialCategory = initialTab.category.id;
const initialRegion = initialTab.regionId;
const domesticTotal = items.filter((item) => item.regionId === 'domestic').length;
const globalTotal = items.filter((item) => item.regionId === 'global').length;
---

<Layout title={`${title} | AI Compass`} description={description} currentPath="/topics/">
	<section class="mx-auto max-w-[760px] lg:mx-0 lg:max-w-none">
		<div class="sticky top-[3.35rem] z-30 -mx-3 border-b border-border bg-background/95 px-3 pt-2 backdrop-blur supports-[backdrop-filter]:bg-background/86 lg:static lg:mx-0 lg:overflow-hidden lg:rounded-lg lg:border lg:bg-[linear-gradient(135deg,hsl(var(--card))_0%,hsl(var(--muted))_58%,hsl(var(--background))_100%)] lg:p-4 lg:shadow-sm">
			<div class="flex items-end justify-between gap-3 pb-2 lg:items-start lg:pb-4">
				<div class="min-w-0">
					<div class="flex items-center gap-2 lg:gap-3">
						<span class="hidden rounded-md border border-primary/25 bg-primary/10 p-2 text-primary lg:inline-flex">
							<Newspaper className="h-5 w-5" />
						</span>
						<Newspaper className="h-4 w-4 text-primary lg:hidden" />
						<h1 class="text-lg font-bold leading-7 text-foreground lg:text-2xl lg:leading-9">AI News</h1>
					</div>
					<p class="mt-0.5 line-clamp-1 text-[11px] leading-5 text-muted-foreground sm:text-xs lg:mt-1 lg:line-clamp-none lg:text-sm lg:leading-6">
						国内ニュースと海外公式アップデートを、短時間で流し読みできる一覧に整理しています。
					</p>
				</div>
				<div class="shrink-0 text-right">
					<p class="text-[10px] leading-4 text-muted-foreground sm:text-[11px]">更新<br />{updatedAt}</p>
					<div class="mt-2 hidden gap-1.5 lg:flex">
						<span class="rounded-full border border-border bg-background/70 px-2.5 py-1 text-xs font-semibold text-muted-foreground">国内 {domesticTotal}</span>
						<span class="rounded-full border border-border bg-background/70 px-2.5 py-1 text-xs font-semibold text-muted-foreground">公式 {globalTotal}</span>
					</div>
				</div>
			</div>

			<div class="-mx-3 overflow-x-auto overscroll-x-contain px-3 pb-1.5 lg:mx-0 lg:px-0 lg:pb-0" role="tablist" aria-label="ニュースカテゴリ">
				<div class="flex w-max min-w-full gap-1.5 lg:gap-2">
					{tabEntries.map(({ category, regionId, count }) => (
						<button
							type="button"
							class={[
								'news-tab h-7 shrink-0 rounded-full border px-2.5 text-[11px] font-semibold leading-none shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring sm:h-8 sm:px-3 sm:text-xs lg:h-9 lg:px-4 lg:text-sm',
								category.id === initialCategory
									? 'border-primary bg-primary text-primary-foreground shadow-primary/20'
									: 'border-border/80 bg-card/90 text-muted-foreground hover:border-primary/40 hover:bg-muted hover:text-foreground'
							].join(' ')}
							data-news-region={regionId}
							data-news-tab={category.id}
							aria-selected={category.id === initialCategory ? 'true' : 'false'}
							role="tab"
						>
							{category.label}
							<span class="ml-1 rounded-full bg-background/75 px-1.5 py-0.5 text-[9px] font-bold text-muted-foreground opacity-90" data-tab-count={category.id}>
								{count}
							</span>
						</button>
					))}
				</div>
			</div>
		</div>

		<div class="mt-3 grid gap-3 touch-pan-y lg:mt-4" data-news-swipe>
			{regions.map((region) =>
				categories.map((category) => {
					const categoryItems = items.filter((item) => item.regionId === region.id && item.categoryId === category.id);
					const active = region.id === initialRegion && category.id === initialCategory;
					const globalCount = itemCount('global', category.id);
					return (
						<section
							class={['news-panel grid gap-2.5 lg:grid-cols-2 lg:gap-3', active ? '' : 'hidden'].filter(Boolean).join(' ')}
							data-news-panel={panelId(region.id, category.id)}
							data-panel-region={region.id}
							data-panel-category={category.id}
							role="tabpanel"
						>
							{categoryItems.length > 0 ? (
								categoryItems.map((item) => (
									<article class="overflow-hidden rounded-md border border-border bg-card shadow-sm transition-colors hover:-translate-y-0.5 hover:bg-muted/45 hover:shadow-md lg:rounded-lg">
										<a
											href={item.url}
											target="_blank"
											rel="noreferrer"
											class="flex min-h-[6.25rem] items-center gap-2.5 p-2.5 no-underline sm:min-h-[8.25rem] sm:gap-3 sm:p-3 lg:min-h-[9rem]"
										>
											<div class="relative h-20 w-24 shrink-0 overflow-hidden rounded-md border border-border bg-secondary sm:h-[6.75rem] sm:w-36 lg:h-28 lg:w-40">
												<img src={item.imageUrl ? resolveImageUrl(item.imageUrl) : fallbackImage} alt="" loading="lazy" referrerpolicy="no-referrer" class="h-full w-full object-cover" onerror={`this.onerror=null;this.src='${fallbackImage}'`} />
											</div>
											<div class="min-w-0 flex-1 self-center">
												<div class="flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 text-[10px] leading-4 text-muted-foreground sm:text-[11px]">
													<span class="truncate font-medium text-foreground">{item.source}</span>
													{item.publishedAt && <span>{formatDate(item.publishedAt)}</span>}
													<Badge variant={item.sourceType === 'official' ? 'default' : 'secondary'} className="h-4 px-1 text-[9px] leading-none sm:h-5 sm:text-[10px]">
														{sourceTypeLabel(item.sourceType)}
													</Badge>
													<Badge variant="outline" className="h-4 px-1 text-[9px] leading-none sm:h-5 sm:text-[10px]">
														{item.language === 'ja' ? '日本語' : '英語'}
													</Badge>
												</div>

												<h3 class="mt-1 line-clamp-2 text-[13px] font-bold leading-5 text-foreground sm:text-base sm:leading-6 lg:text-[17px] lg:leading-7">
													{item.title}
												</h3>

												<span class="sr-only">
													元記事
												</span>
											</div>
										</a>
									</article>
								))
							) : (
								<div class="rounded-md border border-dashed border-border bg-card p-4 text-sm leading-6 text-muted-foreground">
									<p>このカテゴリの{region.label}向け公式ニュースは、まだ取得できていません。</p>
									{region.id === 'domestic' && globalCount > 0 && (
										<p class="mt-2">海外には {globalCount} 件あります。上の「海外」に切り替えると確認できます。</p>
									)}
								</div>
							)}
						</section>
					);
				})
			)}
		</div>
	</section>

	<script is:inline define:vars={{ defaultCategory: initialCategory, defaultRegion: initialRegion }}>
		(() => {
			const tabs = [...document.querySelectorAll('[data-news-tab]')];
			const panels = [...document.querySelectorAll('[data-news-panel]')];
			const counts = [...document.querySelectorAll('[data-tab-count]')];
			const swipeTarget = document.querySelector('[data-news-swipe]');
			const categoryAliases = { anthropic: 'official', claude: 'official', copilot: 'official', gemini: 'official', google: 'official', openai: 'official' };
			let activeRegion = defaultRegion;
			let activeCategory = defaultCategory;
			let activeIndex = Math.max(
				0,
				tabs.findIndex((tab) => tab.dataset.newsRegion === defaultRegion && tab.dataset.newsTab === defaultCategory)
			);
			let touchStartX = 0;
			let touchStartY = 0;
			let touchDeltaX = 0;
			let touchDeltaY = 0;

			function countFor(regionId, categoryId) {
				return panels.find((panel) => panel.dataset.panelRegion === regionId && panel.dataset.panelCategory === categoryId)?.querySelector('article')
					? [...document.querySelectorAll(`article a[href]`)].filter((link) => link.closest('[data-panel-region]')?.dataset.panelRegion === regionId && link.closest('[data-panel-category]')?.dataset.panelCategory === categoryId).length
					: 0;
			}

			function firstVisibleCategory(regionId) {
				const available = tabs.find((tab) => tab.dataset.newsRegion === regionId && countFor(regionId, tab.dataset.newsTab) > 0);
				return available?.dataset.newsTab || tabs[0]?.dataset.newsTab || defaultCategory;
			}

			function setActive(regionId, categoryId, updateHash = true) {
				activeRegion = regionId;
				activeCategory = countFor(regionId, categoryId) > 0 ? categoryId : firstVisibleCategory(regionId);

				tabs.forEach((tab) => {
					const tabRegion = tab.dataset.newsRegion || defaultRegion;
					const tabCategory = tab.dataset.newsTab || defaultCategory;
					const active = tabRegion === activeRegion && tabCategory === activeCategory;
					tab.setAttribute('aria-selected', String(active));
					tab.classList.toggle('border-primary', active);
					tab.classList.toggle('bg-primary', active);
					tab.classList.toggle('text-primary-foreground', active);
					tab.classList.toggle('border-border', !active);
					tab.classList.toggle('bg-background', !active);
					tab.classList.toggle('text-muted-foreground', !active);
					tab.classList.toggle('hover:bg-muted', !active);
					tab.classList.toggle('hover:text-foreground', !active);
					if (active) {
						activeIndex = tabs.indexOf(tab);
						tab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
					}
				});

				panels.forEach((panel) => {
					panel.classList.toggle('hidden', panel.dataset.newsPanel !== `${regionId}:${activeCategory}`);
				});

				counts.forEach((count) => {
					const categoryIdForCount = count.dataset.tabCount;
					const tab = tabs.find((item) => item.dataset.newsTab === categoryIdForCount);
					count.textContent = String(countFor(tab?.dataset.newsRegion || defaultRegion, categoryIdForCount));
				});

				if (updateHash) {
					history.replaceState(null, '', `#${activeCategory}`);
				}
			}

			function setActiveByIndex(index) {
				const nextIndex = Math.min(Math.max(index, 0), tabs.length - 1);
				const tab = tabs[nextIndex];
				if (!tab || nextIndex === activeIndex) return;
				setActive(tab.dataset.newsRegion || defaultRegion, tab.dataset.newsTab || defaultCategory);
			}

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					setActive(tab.dataset.newsRegion || defaultRegion, tab.dataset.newsTab || defaultCategory);
				});
			});

			if (swipeTarget && tabs.length > 1) {
				swipeTarget.addEventListener(
					'touchstart',
					(event) => {
						const touch = event.touches[0];
						if (!touch) return;
						touchStartX = touch.clientX;
						touchStartY = touch.clientY;
						touchDeltaX = 0;
						touchDeltaY = 0;
					},
					{ passive: true }
				);

				swipeTarget.addEventListener(
					'touchmove',
					(event) => {
						const touch = event.touches[0];
						if (!touch) return;
						touchDeltaX = touch.clientX - touchStartX;
						touchDeltaY = touch.clientY - touchStartY;
						if (Math.abs(touchDeltaX) > 16 && Math.abs(touchDeltaX) > Math.abs(touchDeltaY) * 1.25) {
							event.preventDefault();
						}
					},
					{ passive: false }
				);

				swipeTarget.addEventListener('touchend', (event) => {
					const isHorizontalSwipe = Math.abs(touchDeltaX) >= 56 && Math.abs(touchDeltaX) > Math.abs(touchDeltaY) * 1.25;
					if (!isHorizontalSwipe) return;
					event.preventDefault();
					setActiveByIndex(activeIndex + (touchDeltaX < 0 ? 1 : -1));
				});
			}

			const hashCategory = location.hash ? location.hash.slice(1) : defaultCategory;
			const initialCategory = categoryAliases[hashCategory] || hashCategory;
			const initialTab = tabs.find((tab) => tab.dataset.newsTab === initialCategory);
			if (initialTab) {
				setActive(initialTab.dataset.newsRegion || defaultRegion, initialCategory, false);
			} else {
				setActive(defaultRegion, defaultCategory, false);
			}
		})();
	</script>
</Layout>
