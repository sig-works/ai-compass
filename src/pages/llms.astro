---
import LlmComparison from '@/components/common/LlmComparison';
import Layout from '@/layouts/Layout.astro';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

const llmData = JSON.parse(
	await readFile(join(process.cwd(), 'public', 'data', 'llm-latest.json'), 'utf8')
);
---

<Layout
	title="AIモデル選定ガイド | AI Compass"
	description="個人利用から業務利用まで、用途と契約プランに合わせてOpenAI、Claude、GeminiのAIモデルを選ぶためのガイドです。"
	currentPath="/llms/"
>
	<section class="space-y-4">
		<LlmComparison client:load data={llmData} />
	</section>
</Layout>
