---
import LlmComparison from '@/components/common/LlmComparison';
import Layout from '@/layouts/Layout.astro';
import { BadgeCheck, BookOpen, Route, Sparkles } from 'lucide-react';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

const llmData = JSON.parse(
	await readFile(join(process.cwd(), 'public', 'data', 'llm-latest.json'), 'utf8')
);
---

<Layout
	title="AIモデル選定ガイド | AI Compass"
	description="個人利用から業務利用まで、用途と契約プランに合わせてOpenAI、Claude、GeminiのAIモデルを選ぶためのガイドです。"
	currentPath="/llms/"
>
	<section class="space-y-4">
		<header class="rounded-md border border-border bg-card p-4 shadow-sm">
			<div class="flex flex-wrap items-start justify-between gap-4">
				<div class="max-w-4xl">
					<p class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground">
						<BookOpen className="h-3.5 w-3.5" />
						モデル選定
					</p>
					<h1 class="mt-1 text-2xl font-semibold tracking-tight">AIモデル選定ガイド</h1>
					<p class="mt-2 text-sm leading-6 text-muted-foreground">
						「どのAIを使えばいいか」を、専門用語ではなく
						<span class="font-medium text-foreground">用途</span>、
						<span class="font-medium text-foreground">契約プラン</span>、
						<span class="font-medium text-foreground">精度・速度・コスト</span>
						から選ぶためのガイドです。個人利用から業務利用まで、要件定義、設計、コード、文章、画像、データ分析で選ぶ前に見るポイントをまとめています。
					</p>
				</div>

				<div class="grid gap-2 sm:grid-cols-3">
					<div class="rounded-md border border-border bg-background px-3 py-2">
						<div class="flex items-center gap-2">
							<Route className="h-4 w-4 text-primary" />
							<p class="text-sm font-semibold text-foreground">用途から選ぶ</p>
						</div>
						<p class="mt-1 text-xs leading-5 text-muted-foreground">作業別に候補を確認</p>
					</div>
					<div class="rounded-md border border-border bg-background px-3 py-2">
						<div class="flex items-center gap-2">
							<BadgeCheck className="h-4 w-4 text-primary" />
							<p class="text-sm font-semibold text-foreground">プランで分ける</p>
						</div>
						<p class="mt-1 text-xs leading-5 text-muted-foreground">無料 / Pro / 企業利用</p>
					</div>
					<div class="rounded-md border border-border bg-background px-3 py-2">
						<div class="flex items-center gap-2">
							<Sparkles className="h-4 w-4 text-primary" />
							<p class="text-sm font-semibold text-foreground">特徴で比較</p>
						</div>
						<p class="mt-1 text-xs leading-5 text-muted-foreground">特徴・得意・苦手を見る</p>
					</div>
				</div>
			</div>

			<div class="mt-4 rounded-md border border-border bg-background p-3">
				<h2 class="text-sm font-semibold text-foreground">このガイドの目的と使い方</h2>
				<div class="mt-2 grid gap-2 text-sm leading-6 text-muted-foreground md:grid-cols-3">
					<p>1. まず「無料で試す」「毎日使う」「会社で使う」のどれに近いかを選びます。</p>
					<p>2. 次に、要件定義、コードレビュー、画像生成など、自分の用途を選びます。</p>
					<p>3. 最後に、推奨モデル、注意点、契約プラン別の代替案を見て選びます。</p>
				</div>
			</div>
		</header>

		<LlmComparison client:load data={llmData} />
	</section>
</Layout>
