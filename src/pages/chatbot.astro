---
import ChatbotGuide from '@/components/common/ChatbotGuide';
import Layout from '@/layouts/Layout.astro';
import { Bot, Circle } from 'lucide-react';
---

<Layout title="チャットボット | AI Compass" description="AI CompassのチャットボットUIです。" currentPath="/chatbot/">
  <section class="flex h-[calc(100dvh-6.5rem)] max-h-[calc(100dvh-6.5rem)] flex-col overflow-hidden rounded-lg border border-border bg-card shadow-sm">
    <header class="flex shrink-0 items-center justify-between gap-3 border-b border-border bg-card/95 px-3 py-2.5 backdrop-blur sm:px-4">
      <div class="flex min-w-0 items-center gap-2.5">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-primary/20 bg-primary/10 text-primary">
          <Bot className="h-5 w-5" />
        </span>
        <div class="min-w-0">
          <h1 class="truncate text-base font-bold leading-6 text-foreground">チャットボット</h1>
          <div class="mt-0.5 flex items-center gap-1.5 text-xs text-muted-foreground">
            <Circle className="h-2 w-2 fill-primary text-primary" />
            <span>オンライン</span>
          </div>
        </div>
      </div>
    </header>

    <ChatbotGuide client:load />
  </section>
</Layout>
