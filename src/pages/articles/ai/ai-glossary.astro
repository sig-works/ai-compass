---
import CodeConsole from '@/components/common/CodeConsole.astro';
import TermTooltip from '@/components/common/TermTooltip.astro';
import Layout from '@/layouts/Layout.astro';
import { BookOpen, CheckCircle2, ClipboardCheck, Compass, FileText, ShieldCheck, Sparkles, TriangleAlert } from 'lucide-react';

const quickStart = [
	{
		label: '任せやすい',
		title: '材料がある作業',
		description: '要約、下書き、分類、比較、言い換えのように、人が確認できる材料から形を作る作業。',
	},
	{
		label: '注意する',
		title: '根拠が必要な答え',
		description: '数字、固有名詞、最新情報、仕様、引用は、AIの文章ではなく一次情報で確かめる。',
	},
	{
		label: '最初に試す',
		title: '戻しやすい小仕事',
		description: '自分が内容を理解している文章で、要点整理、確認質問、表現調整から始める。',
	},
];

const usefulTasks = [
	{
		icon: FileText,
		title: '読む量を減らす',
		description: '長い文章を要点、未決事項、次の作業に分けます。全部を読まないためではなく、読む順番を決めるために使います。',
	},
	{
		icon: Sparkles,
		title: '書き出しを作る',
		description: 'メール、説明文、README、提案書のたたき台を作ります。最初の空白を埋め、あとから人が整える用途に向いています。',
	},
	{
		icon: Compass,
		title: '観点を増やす',
		description: 'テスト観点、レビュー観点、リスク、確認質問を出してもらいます。抜け漏れを減らす補助として使えます。',
	},
	{
		icon: ClipboardCheck,
		title: '言い換える',
		description: '硬い文章を読みやすくする、短くする、相手に合わせた表現に直す、といった文章調整に向いています。',
	},
];

const checks = [
	'数字や固有名詞は、公式ページや手元の資料で照合する。',
	'コードは実行し、テストやレビューを通してから使う。',
	'重要な判断は、AIの答えではなく確認済みの根拠で決める。',
	'不明点は「何を根拠にしたか」「自信が低い点はどこか」と聞き返す。',
];

const starterSteps = [
	'自分が内容を理解している文章を選ぶ',
	'要約、観点出し、言い換えのどれか1つに絞る',
	'断定できないことを「要確認」として残させる',
	'出てきた答えを元資料と見比べて直す',
];
---

<Layout title="AI入門 | AI Compass" description="AIでできること、苦手なこと、最初の試し方をまとめた記事。" currentPath="/articles/ai/ai-glossary/">
	<article class="article-shell">
		<div class="article-prose">
			<header class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end">
				<div>
					<p class="inline-flex items-center gap-2 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">
						<BookOpen className="h-3.5 w-3.5" />
						基礎ガイド
					</p>
					<h1>AI入門</h1>
					<p class="article-lead">
						AIは、人の代わりにすべてを決めるものではなく、調べる、整理する、書き出す、見直す作業を速くするための道具です。
						まずは「任せやすい作業」「間違いやすい場所」「確かめ方」を分けて考えると、使い始めやすくなります。
					</p>
				</div>
				<aside class="rounded-md border border-primary/20 bg-secondary/60 p-4 text-sm leading-6 text-secondary-foreground shadow-sm">
					<p class="mt-0 text-xs font-semibold text-foreground">最初の結論</p>
					<p class="mt-2">
						AIは答えを確定する相手ではなく、確認前の材料を早く出す相手です。
					</p>
				</aside>
			</header>

			<section class="not-prose mt-6 grid gap-3 md:grid-cols-3">
				{quickStart.map((item) => (
					<div class="rounded-md border border-border bg-background p-3 shadow-sm">
						<p class="mt-0 text-[11px] font-semibold text-primary">{item.label}</p>
						<p class="mt-2 text-base font-bold text-foreground">{item.title}</p>
						<p class="mt-2 text-sm leading-6 text-muted-foreground">{item.description}</p>
					</div>
				))}
			</section>

			<h2>AIは何を助けるものか</h2>
			<p>
				いま実務でよく使われるAIの中心は、文章を読んで返答を作る <TermTooltip term="LLM" /> です。
				人が依頼文を書き、AIがその内容に沿って文章、表、手順、コードの下書きなどを返します。
				重要なのは、AIを「答えをそのまま出す機械」ではなく、「考える材料を早く出す相手」と見ることです。
			</p>
			<p>
				たとえば、議事録を要点にまとめる、長い仕様書から確認点を出す、文章を読みやすく直す、レビュー観点を洗い出す、といった場面では効果が出やすいです。
				一方で、法務判断、医療判断、契約条件、売上数値、セキュリティ設定のように間違いの影響が大きいものは、人の確認を前提にします。
			</p>

			<h2>最初に任せやすい作業</h2>
			<div class="not-prose mt-4 grid gap-3 md:grid-cols-2">
				{usefulTasks.map((task) => (
					<div class="rounded-md border border-border bg-background p-4 shadow-sm">
						<div class="flex items-start gap-3">
							<span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-border bg-card text-primary">
								<task.icon className="h-4 w-4" />
							</span>
							<div class="min-w-0">
								<p class="mt-0 text-sm font-semibold text-foreground">{task.title}</p>
								<p class="mt-2 text-sm leading-6 text-muted-foreground">{task.description}</p>
							</div>
						</div>
					</div>
				))}
			</div>

			<h2>苦手なことと確認方法</h2>
			<p>
				AIは自然な文章を作れるため、正しそうに見える誤りを出すことがあります。これは <TermTooltip term="幻覚" label="ハルシネーション" /> と呼ばれます。
				特に、最新情報、数字、引用、仕様、固有名詞はそのまま採用せず、一次情報や手元の資料で確認します。
			</p>
			<div class="not-prose mt-4 grid gap-3 lg:grid-cols-[16rem_minmax(0,1fr)]">
				<div class="rounded-md border border-destructive/25 bg-background p-4 shadow-sm">
					<div class="flex items-center gap-2 text-sm font-semibold text-foreground">
						<TriangleAlert className="h-4 w-4 text-destructive" />
						そのまま採用しない
					</div>
					<p class="mt-2 text-sm leading-6 text-muted-foreground">
						文章が自然でも、根拠が正しいとは限りません。影響が大きいものほど確認の手順を先に決めます。
					</p>
				</div>
				<div class="rounded-md border border-border bg-background p-4 shadow-sm">
					<div class="flex items-center gap-2 text-sm font-semibold text-foreground">
						<ShieldCheck className="h-4 w-4 text-primary" />
						確認チェック
					</div>
					<ul class="mt-3 grid gap-2 pl-0">
						{checks.map((check) => (
							<li class="flex gap-2 text-sm leading-6 text-muted-foreground">
								<CheckCircle2 className="mt-1 h-4 w-4 shrink-0 text-primary" />
								<span>{check}</span>
							</li>
						))}
					</ul>
				</div>
			</div>

			<h2>最初の試し方</h2>
			<p>
				最初から大きな業務を任せるより、失敗しても戻しやすい作業で試すのが安全です。
				すでに自分が内容を理解している文章を使い、要約、観点出し、言い換えを比べると、AIの得意不得意を判断しやすくなります。
			</p>
			<ol class="not-prose mt-4 grid gap-2 pl-0">
				{starterSteps.map((step, index) => (
					<li class="flex items-center gap-3 rounded-md border border-border bg-background px-3 py-2 text-sm leading-6 text-muted-foreground shadow-sm">
						<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-border bg-card text-xs font-semibold text-foreground">
							{index + 1}
						</span>
						<span>{step}</span>
					</li>
				))}
			</ol>

			<CodeConsole title="最初に試す依頼文" language="text" tone="prompt">
{`次の文章を、仕事で確認しやすい形に整理してください。

やってほしいこと:
- 要点を3つにまとめる
- 未決のことを分ける
- 次に確認すべき質問を出す
- 断定できないことは「要確認」と書く

文章:
（ここにメール、議事録、仕様メモを貼る）`}
			</CodeConsole>

			<h2>次に読むページ</h2>
			<div class="not-prose mt-4 grid gap-3 md:grid-cols-2">
				<a class="rounded-md border border-border bg-background p-4 text-foreground no-underline shadow-sm hover:bg-muted" href="/articles/ai/llm-basics/">
					<p class="mt-0 text-sm font-semibold">LLMとは？</p>
					<p class="mt-2 text-sm leading-6 text-muted-foreground">言葉で頼むAIの仕組み、依頼文の基本、モデル選びの目安を確認します。</p>
				</a>
				<a class="rounded-md border border-border bg-background p-4 text-foreground no-underline shadow-sm hover:bg-muted" href="/articles/ai/safety-guide/">
					<p class="mt-0 text-sm font-semibold">安全なAI活用</p>
					<p class="mt-2 text-sm leading-6 text-muted-foreground">入力してよい情報、答えの確認、共有前チェックを決めます。</p>
				</a>
			</div>

			<h2>参考資料</h2>
			<div class="source-list">
				<a href="https://platform.openai.com/docs/guides/prompt-engineering" target="_blank" rel="noreferrer">OpenAI: Prompt engineering</a>
				<a href="https://ai.google.dev/gemini-api/docs/prompting-strategies?hl=ja" target="_blank" rel="noreferrer">Google AI for Developers: Prompting strategies</a>
				<a href="https://support.microsoft.com/ja-jp/copilot" target="_blank" rel="noreferrer">Microsoft Copilot</a>
			</div>
		</div>
	</article>
</Layout>
