---
import { Badge } from '@/components/ui/badge';
import Layout from '@/layouts/Layout.astro';
import aiVideos from '@/data/ai-videos.json';
import { ExternalLink, PlaySquare } from 'lucide-react';

const title = 'AI動画';
const description = 'AIやLLMを学ぶためのYouTube動画を、許可済みチャンネルから自動収集して確認できるページ。';
const categories = aiVideos.categories ?? [];
const items = aiVideos.items ?? [];
const updatedAt = aiVideos.generatedAt
  ? new Intl.DateTimeFormat('ja-JP', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit'
    }).format(new Date(aiVideos.generatedAt))
  : '未更新';

function formatDate(value: string) {
  if (!value) return '';

  return new Intl.DateTimeFormat('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(new Date(value));
}

function sourceTypeLabel(value: string) {
  if (value === 'official') return '公式';
  if (value === 'educator') return '定番講義';
  return '準公式';
}

const activeCategory = categories.find((category) => items.some((item) => item.categoryId === category.id))?.id ?? categories[0]?.id ?? 'learn';
const total = items.length;
---

<Layout title={`${title} | AI Compass`} description={description} currentPath="/videos/">
	<section class="mx-auto max-w-[760px] lg:mx-0 lg:max-w-none">
		<div class="sticky top-[3.35rem] z-30 -mx-3 border-b border-border bg-background/95 px-3 pt-2 backdrop-blur supports-[backdrop-filter]:bg-background/86 lg:static lg:mx-0 lg:overflow-hidden lg:rounded-lg lg:border lg:bg-[linear-gradient(135deg,hsl(var(--card))_0%,hsl(var(--muted))_58%,hsl(var(--background))_100%)] lg:p-4 lg:shadow-sm">
			<div class="flex items-end justify-between gap-3 pb-2 lg:items-start lg:pb-4">
				<div class="min-w-0">
					<div class="flex items-center gap-2 lg:gap-3">
						<span class="hidden rounded-md border border-primary/25 bg-primary/10 p-2 text-primary lg:inline-flex">
							<PlaySquare className="h-5 w-5" />
						</span>
						<PlaySquare className="h-4 w-4 text-primary lg:hidden" />
						<h1 class="text-lg font-bold leading-7 text-foreground lg:text-2xl lg:leading-9">{title}</h1>
					</div>
					<p class="mt-0.5 line-clamp-1 text-[11px] leading-5 text-muted-foreground sm:text-xs lg:mt-1 lg:line-clamp-none lg:text-sm lg:leading-6">
						許可済みYouTubeチャンネルから、AIを学ぶ入口になる動画を自動で整理します。
					</p>
				</div>
				<div class="shrink-0 text-right">
					<p class="text-[10px] leading-4 text-muted-foreground sm:text-[11px]">更新<br />{updatedAt}</p>
					<div class="mt-2 hidden gap-1.5 lg:flex">
						<span class="rounded-full border border-border bg-background/70 px-2.5 py-1 text-xs font-semibold text-muted-foreground">動画 {total}</span>
					</div>
				</div>
			</div>

			{categories.length > 0 && (
				<div class="-mx-3 overflow-x-auto overscroll-x-contain px-3 pb-1.5 lg:mx-0 lg:px-0 lg:pb-0" role="tablist" aria-label="AI動画カテゴリ">
					<div class="flex w-max min-w-full gap-1.5 lg:gap-2">
						{categories.map((category) => {
							const count = items.filter((item) => item.categoryId === category.id).length;
							const active = category.id === activeCategory;
							return (
								<button
									type="button"
									class={[
										'video-tab h-7 shrink-0 rounded-full border px-2.5 text-[11px] font-semibold leading-none shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring sm:h-8 sm:px-3 sm:text-xs lg:h-9 lg:px-4 lg:text-sm',
										active
											? 'border-primary bg-primary text-primary-foreground shadow-primary/20'
											: 'border-border/80 bg-card/90 text-muted-foreground hover:border-primary/40 hover:bg-muted hover:text-foreground'
									].join(' ')}
									data-video-tab={category.id}
									aria-selected={active ? 'true' : 'false'}
									role="tab"
								>
									{category.label}
									<span class="ml-1 rounded-full bg-background/75 px-1.5 py-0.5 text-[9px] font-bold text-muted-foreground opacity-90">
										{count}
									</span>
								</button>
							);
						})}
					</div>
				</div>
			)}
		</div>

		<div class="mt-3 grid gap-3 lg:mt-4">
			{items.length > 0 ? (
				categories.map((category) => {
					const categoryItems = items.filter((item) => item.categoryId === category.id);
					const active = category.id === activeCategory;
					return (
						<section
							class={['video-panel grid gap-2.5 lg:grid-cols-2 lg:gap-3', active ? '' : 'hidden'].filter(Boolean).join(' ')}
							data-video-panel={category.id}
							role="tabpanel"
						>
							{categoryItems.map((item) => (
								<article class="overflow-hidden rounded-md border border-border bg-card shadow-sm transition-colors hover:-translate-y-0.5 hover:bg-muted/45 hover:shadow-md lg:rounded-lg">
									<a href={item.url} target="_blank" rel="noreferrer" class="flex min-h-[6.75rem] items-center gap-2.5 p-2.5 no-underline sm:min-h-[8.5rem] sm:gap-3 sm:p-3 lg:min-h-[9.5rem]">
										<div class="relative h-20 w-28 shrink-0 overflow-hidden rounded-md border border-border bg-secondary sm:h-[6.75rem] sm:w-40 lg:h-28 lg:w-44">
											<img src={item.imageUrl} alt="" loading="lazy" referrerpolicy="no-referrer" class="h-full w-full object-cover" />
											<span class="absolute inset-0 flex items-center justify-center bg-black/12 text-white">
												<PlaySquare className="h-7 w-7 drop-shadow" />
											</span>
										</div>
										<div class="min-w-0 flex-1 self-center">
											<div class="flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 text-[10px] leading-4 text-muted-foreground sm:text-[11px]">
												<span class="truncate font-medium text-foreground">{item.source}</span>
												{item.publishedAt && <span>{formatDate(item.publishedAt)}</span>}
												<Badge variant={item.sourceType === 'official' ? 'default' : 'secondary'} className="h-4 px-1 text-[9px] leading-none sm:h-5 sm:text-[10px]">
													{sourceTypeLabel(item.sourceType)}
												</Badge>
												<Badge variant="outline" className="h-4 px-1 text-[9px] leading-none sm:h-5 sm:text-[10px]">
													{item.language === 'ja' ? '日本語' : '英語'}
												</Badge>
											</div>

											<h2 class="mt-1 line-clamp-2 text-[13px] font-bold leading-5 text-foreground sm:text-base sm:leading-6 lg:text-[17px] lg:leading-7">
												{item.title}
											</h2>
											{item.description && (
												<p class="mt-1 line-clamp-2 text-[11px] leading-5 text-muted-foreground sm:text-xs sm:leading-5">
													{item.description}
												</p>
											)}
											<span class="mt-1 inline-flex items-center gap-1 text-[10px] font-semibold text-primary sm:text-[11px]">
												YouTubeで見る
												<ExternalLink className="h-3 w-3" />
											</span>
										</div>
									</a>
								</article>
							))}
						</section>
					);
				})
			) : (
				<div class="rounded-md border border-dashed border-border bg-card p-4 text-sm leading-6 text-muted-foreground">
					<p>AI動画データはまだありません。手動更新で取得すると、ここに表示されます。</p>
				</div>
			)}
		</div>
	</section>

	<script is:inline define:vars={{ defaultCategory: activeCategory }}>
		(() => {
			const tabs = [...document.querySelectorAll('[data-video-tab]')];
			const panels = [...document.querySelectorAll('[data-video-panel]')];

			function setActive(categoryId) {
				tabs.forEach((tab) => {
					const active = tab.dataset.videoTab === categoryId;
					tab.setAttribute('aria-selected', String(active));
					tab.classList.toggle('border-primary', active);
					tab.classList.toggle('bg-primary', active);
					tab.classList.toggle('text-primary-foreground', active);
					tab.classList.toggle('border-border', !active);
					tab.classList.toggle('bg-card/90', !active);
					tab.classList.toggle('text-muted-foreground', !active);
					tab.classList.toggle('hover:bg-muted', !active);
					tab.classList.toggle('hover:text-foreground', !active);
				});

				panels.forEach((panel) => {
					panel.classList.toggle('hidden', panel.dataset.videoPanel !== categoryId);
				});

				if (categoryId) history.replaceState(null, '', `#${categoryId}`);
			}

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => setActive(tab.dataset.videoTab || defaultCategory));
			});

			const hashCategory = location.hash ? location.hash.slice(1) : defaultCategory;
			const initialTab = tabs.find((tab) => tab.dataset.videoTab === hashCategory);
			setActive(initialTab?.dataset.videoTab || defaultCategory);
		})();
	</script>
</Layout>
