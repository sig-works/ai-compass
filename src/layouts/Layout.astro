---
import ThemeToggle from '@/components/common/ThemeToggle';
import { Card } from '@/components/ui/card';
import { NavigationMenu, NavigationMenuItem, NavigationMenuLink, NavigationMenuList } from '@/components/ui/navigation-menu';
import { ScrollArea } from '@/components/ui/scroll-area';
import { SITE_DESCRIPTION, SITE_NAME } from '@/lib/content';
import { CORE_PAGES, GUIDE_PAGES, REFERENCE_PAGES, navUrl } from '@/lib/navigation';
import { Menu } from 'lucide-react';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  immersive?: boolean;
}

const { title = SITE_NAME, description = SITE_DESCRIPTION, currentPath = Astro.url.pathname, immersive = false } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const pageUrl = canonical ?? Astro.url.toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': currentPath === '/' ? 'WebSite' : 'WebPage',
  name: title,
  description,
  url: pageUrl,
  inLanguage: 'ja',
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_NAME,
    url: Astro.site?.toString() ?? pageUrl
  }
};
const themeBootScript = `(function () {
  const stored = localStorage.getItem('theme-preference') || 'system';
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const resolved = stored === 'system' ? (prefersDark ? 'dark' : 'light') : stored;
  document.documentElement.classList.toggle('dark', resolved === 'dark');
  document.documentElement.dataset.themePreference = stored;
})();`;

const termTooltipScript = `(function () {
  const isTouchLike = window.matchMedia('(hover: none), (pointer: coarse)');
  const closeAll = () => {
    document.querySelectorAll('.term-chip.is-open').forEach((chip) => {
      chip.classList.remove('is-open');
      chip.setAttribute('aria-expanded', 'false');
    });
  };

  document.addEventListener('click', (event) => {
    if (!isTouchLike.matches) return;
    const chip = event.target.closest && event.target.closest('.term-chip');

    if (!chip) {
      closeAll();
      return;
    }

    event.preventDefault();
    const wasOpen = chip.classList.contains('is-open');
    closeAll();

    if (!wasOpen) {
      chip.classList.add('is-open');
      chip.setAttribute('aria-expanded', 'true');
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeAll();
  });

  window.addEventListener('scroll', closeAll, { passive: true });
})();`;

const normalizePath = (path: string) => (path.endsWith('/') ? path : `${path}/`);
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  if (href === '/llms/') return normalizePath(currentPath) === '/llms/';
  return normalizePath(currentPath).startsWith(normalizePath(href));
};
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={navUrl('/favicon.svg')} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{canonical && <link rel="canonical" href={canonical} />}
		<meta property="og:type" content={currentPath === '/' ? 'website' : 'article'} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:locale" content="ja_JP" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
		<script is:inline set:html={themeBootScript}></script>
		<script is:inline set:html={termTooltipScript}></script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-4SDN3T6L16"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-4SDN3T6L16');
		</script>
	</head>
	<body>
		<div class="min-h-screen overflow-x-clip">
			<header class="sticky top-0 z-40 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/86">
				<div class="mx-auto flex w-full max-w-[1500px] items-center justify-between gap-2 px-3 py-2.5 lg:px-5 lg:py-3">
					<a href={navUrl('/')} class="flex min-w-0 flex-1 items-center gap-2.5 pl-10 sm:pl-11 lg:gap-3 lg:pl-0">
						<img src={navUrl('/brand/ai-compass-wordmark-light.png')} alt={SITE_NAME} class="h-8 w-auto max-w-[156px] object-contain dark:hidden sm:h-9 sm:max-w-[176px]" />
						<img src={navUrl('/brand/ai-compass-wordmark-dark.png')} alt={SITE_NAME} class="hidden h-8 w-auto max-w-[156px] object-contain dark:block sm:h-9 sm:max-w-[176px]" />
					</a>

					<div class="flex shrink-0 items-center gap-1.5">
						<details class="group fixed left-3 top-2.5 z-50 lg:hidden">
							<summary
								class="flex h-8 w-8 cursor-pointer list-none items-center justify-center rounded-md border border-primary/25 bg-card text-foreground shadow-sm transition-colors hover:bg-primary/10 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
								aria-label="ナビゲーションメニュー"
							>
								<Menu className="h-4 w-4" />
							</summary>
							<div class="fixed left-3 right-3 top-[3.75rem] z-50 overflow-hidden rounded-lg border border-border bg-popover text-popover-foreground shadow-xl">
								<nav class="max-h-[min(36rem,calc(100dvh-4.5rem))] overflow-y-auto p-2.5" aria-label="Mobile navigation">
									<div class="mb-2 rounded-md border border-border bg-[linear-gradient(135deg,hsl(var(--card))_0%,hsl(var(--muted))_100%)] p-3">
										<p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-primary">AI Compass</p>
										<p class="mt-1 text-sm font-bold leading-5 text-foreground">読みたい場所へ移動</p>
									</div>

									<div class="grid gap-2">
										<div>
											<p class="px-2 pb-1 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">主要</p>
											<div class="grid grid-cols-2 gap-1.5">
												{CORE_PAGES.map((item) => (
													<a
														href={navUrl(item.href)}
														class={[
															'rounded-md border border-border bg-card px-3 py-2 text-sm no-underline shadow-sm transition-colors hover:bg-muted hover:text-foreground',
															isActive(item.href) ? 'border-primary/40 bg-primary/10 text-foreground' : 'text-muted-foreground'
														].filter(Boolean).join(' ')}
													>
														<span class="block font-medium">{item.label}</span>
														<span class="mt-0.5 block line-clamp-2 text-[11px] leading-4 text-muted-foreground">{item.description}</span>
													</a>
												))}
											</div>
										</div>

										<div class="border-t border-border pt-2">
											<p class="px-2 pb-1 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">はじめに読む</p>
											<div class="grid gap-0.5">
												{GUIDE_PAGES.map((item) => (
													<a
														href={navUrl(item.href)}
														class={[
															'rounded-md border border-transparent px-3 py-2 text-sm no-underline transition-colors hover:border-border hover:bg-muted hover:text-foreground',
															isActive(item.href) ? 'border-primary/30 bg-secondary text-secondary-foreground' : 'text-muted-foreground'
														].filter(Boolean).join(' ')}
													>
														<span class="block font-medium">{item.label}</span>
														<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
													</a>
												))}
											</div>
										</div>

										<div class="border-t border-border pt-2">
											<p class="px-2 pb-1 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">調べる・使う</p>
											<div class="grid gap-0.5">
												{REFERENCE_PAGES.map((item) => (
													<div>
														<a
															href={navUrl(item.href)}
															class={[
																'block rounded-md px-3 py-2 text-sm no-underline transition-colors hover:bg-muted hover:text-foreground',
																isActive(item.href) ? 'bg-secondary text-secondary-foreground' : 'text-muted-foreground'
															].filter(Boolean).join(' ')}
														>
															<span class="block font-medium">{item.label}</span>
															<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
														</a>
														{item.children && (
															<details
																class="mt-1 rounded-md border border-border bg-background/40 p-2"
																open={item.children.some((group) => isActive(group.href) || group.children?.some((child) => isActive(child.href)))}
															>
																<summary class="cursor-pointer rounded-md px-2 py-1 text-xs font-semibold text-muted-foreground hover:bg-muted hover:text-foreground">
																	モデル一覧
																</summary>
																<div class="mt-1 grid gap-2">
																	{item.children.map((group) => (
																		<div class="rounded-md border border-border/70 bg-card/70 p-2">
																			<a href={navUrl(group.href)} class="block rounded-md px-2 py-1 text-xs font-semibold text-muted-foreground no-underline hover:bg-muted hover:text-foreground">
																				{group.label}
																			</a>
																			{group.children && (
																				<div class="mt-1 grid grid-cols-2 gap-1 sm:grid-cols-3">
																					{group.children.map((child) => (
																						<a
																							href={navUrl(child.href)}
																							class={[
																								'min-w-0 rounded-md border border-border bg-background px-2 py-1 text-xs leading-4 text-muted-foreground no-underline hover:bg-muted hover:text-foreground',
																								isActive(child.href) ? 'bg-secondary text-foreground' : ''
																							].filter(Boolean).join(' ')}
																						>
																							<span class="block truncate">{child.label}</span>
																						</a>
																					))}
																				</div>
																			)}
																		</div>
																	))}
																</div>
															</details>
														)}
													</div>
												))}
											</div>
										</div>
									</div>
								</nav>
							</div>
						</details>

						<ThemeToggle client:load />
					</div>
				</div>
			</header>

			<div class:list={[
				'mx-auto grid w-full grid-cols-1 gap-3 px-3 py-3 lg:gap-4 lg:px-5 lg:py-4',
				immersive ? 'max-w-[1800px]' : 'max-w-[1500px] lg:grid-cols-[250px_minmax(0,1fr)]'
			]}>
				{!immersive && <aside class="hidden lg:block">
					<Card className="sticky top-16">
						<ScrollArea className="max-h-[calc(100dvh-5rem)] p-2">
							<NavigationMenu>
								<div class="px-2 pb-2">
									<p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground">Navigation</p>
								</div>
								<NavigationMenuList>
									{CORE_PAGES.map((item) => (
										<NavigationMenuItem>
											<NavigationMenuLink
												href={navUrl(item.href)}
												className={isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''}
											>
												<span class="block font-medium">{item.label}</span>
												<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
											</NavigationMenuLink>
										</NavigationMenuItem>
									))}
								</NavigationMenuList>

								<div class="mt-3 border-t border-border pt-3">
									<p class="px-2 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">はじめに読む</p>
									<NavigationMenuList className="mt-2 gap-0.5">
										{GUIDE_PAGES.map((item) => (
											<NavigationMenuItem>
												<NavigationMenuLink
													href={navUrl(item.href)}
													className={['py-1.5', isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''].filter(Boolean).join(' ')}
												>
													<span class="block font-medium">{item.label}</span>
													<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
												</NavigationMenuLink>
											</NavigationMenuItem>
										))}
									</NavigationMenuList>
								</div>

								<div class="mt-3 border-t border-border pt-3">
									<p class="px-2 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">調べる・使う</p>
									<NavigationMenuList className="mt-2 gap-0.5">
										{REFERENCE_PAGES.map((item) => (
											<NavigationMenuItem>
												{item.children ? (
													<details
														class="group rounded-md"
														open={isActive(item.href) || item.children.some((group) => isActive(group.href) || group.children?.some((child) => isActive(child.href)))}
													>
														<summary
															class={[
																'flex cursor-pointer list-none items-start justify-between gap-2 rounded-md px-3 py-1.5 text-sm transition-colors hover:bg-accent hover:text-accent-foreground',
																isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''
															].filter(Boolean).join(' ')}
														>
															<a href={navUrl(item.href)} class="min-w-0 flex-1 text-inherit no-underline">
																<span class="block font-medium">{item.label}</span>
																<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
															</a>
															<span class="mt-1 text-xs text-muted-foreground transition-transform group-open:rotate-90">›</span>
														</summary>
														<div class="ml-3 mt-1 border-l border-border pl-2">
															{item.children.map((group) => (
																<div class="py-1">
																	<a href={navUrl(group.href)} class="block rounded-md px-2 py-1 text-xs font-semibold text-muted-foreground no-underline hover:bg-muted hover:text-foreground">
																		{group.label}
																	</a>
																	{group.children && (
																		<div class="mt-0.5 grid gap-0.5">
																			{group.children.map((child) => (
																				<a
																					href={navUrl(child.href)}
																					class={[
																						'block rounded-md px-2 py-1 text-xs text-muted-foreground no-underline hover:bg-muted hover:text-foreground',
																						isActive(child.href) ? 'bg-secondary text-foreground' : ''
																					].filter(Boolean).join(' ')}
																				>
																					{child.label}
																				</a>
																			))}
																		</div>
																	)}
																</div>
															))}
														</div>
													</details>
												) : (
													<NavigationMenuLink
														href={navUrl(item.href)}
														className={['py-1.5', isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''].filter(Boolean).join(' ')}
													>
														<span class="block font-medium">{item.label}</span>
														<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
													</NavigationMenuLink>
												)}
											</NavigationMenuItem>
										))}
									</NavigationMenuList>
								</div>
							</NavigationMenu>
						</ScrollArea>
					</Card>
				</aside>}

				<main class="min-w-0 pb-12">
					<slot />
				</main>
			</div>
		</div>
	</body>
</html>
