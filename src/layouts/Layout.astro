---
import ThemeToggle from '@/components/common/ThemeToggle';
import { Card } from '@/components/ui/card';
import { NavigationMenu, NavigationMenuItem, NavigationMenuLink, NavigationMenuList } from '@/components/ui/navigation-menu';
import { ScrollArea } from '@/components/ui/scroll-area';
import { SITE_DESCRIPTION, SITE_NAME } from '@/lib/content';
import { CORE_PAGES, GUIDE_PAGES, REFERENCE_PAGES, STATIC_PAGES, navUrl } from '@/lib/navigation';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const { title = SITE_NAME, description = SITE_DESCRIPTION, currentPath = Astro.url.pathname } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const pageUrl = canonical ?? Astro.url.toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': currentPath === '/' ? 'WebSite' : 'WebPage',
  name: title,
  description,
  url: pageUrl,
  inLanguage: 'ja',
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_NAME,
    url: Astro.site?.toString() ?? pageUrl
  }
};
const themeBootScript = `(function () {
  const stored = localStorage.getItem('theme-preference') || 'system';
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const resolved = stored === 'system' ? (prefersDark ? 'dark' : 'light') : stored;
  document.documentElement.classList.toggle('dark', resolved === 'dark');
  document.documentElement.dataset.themePreference = stored;
})();`;

const normalizePath = (path: string) => (path.endsWith('/') ? path : `${path}/`);
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  if (href === '/llms/') return normalizePath(currentPath) === '/llms/';
  return normalizePath(currentPath).startsWith(normalizePath(href));
};
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{canonical && <link rel="canonical" href={canonical} />}
		<meta property="og:type" content={currentPath === '/' ? 'website' : 'article'} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:locale" content="ja_JP" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
		<script is:inline set:html={themeBootScript}></script>
	</head>
	<body>
		<div class="min-h-screen overflow-x-clip">
			<header class="sticky top-0 z-40 border-b border-border bg-background">
				<div class="mx-auto flex w-full max-w-[1500px] items-center justify-between gap-3 px-3 py-3 lg:px-5">
					<a href={navUrl('/')} class="flex min-w-0 items-center gap-3">
						<div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-border bg-card text-primary shadow-sm">
							<svg viewBox="0 0 32 32" role="img" aria-label="AI Compass logo" class="h-6 w-6">
								<circle cx="16" cy="16" r="12" fill="none" stroke="currentColor" stroke-width="1.6" opacity="0.45" />
								<path d="M19.6 12.4 12 20l2.4-6 7.6-7.6-2.4 6Z" fill="currentColor" />
								<path d="M12.4 19.6 20 12l-2.4 6L10 25.6l2.4-6Z" fill="currentColor" opacity="0.45" />
								<circle cx="16" cy="16" r="1.8" fill="currentColor" />
								<path d="M7 16h3.2M21.8 16H25M16 7v3.2M16 21.8V25" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.65" />
								<circle cx="7" cy="16" r="1.4" fill="currentColor" />
								<circle cx="25" cy="16" r="1.4" fill="currentColor" />
								<circle cx="16" cy="7" r="1.4" fill="currentColor" />
								<circle cx="16" cy="25" r="1.4" fill="currentColor" />
							</svg>
						</div>
						<div class="min-w-0">
							<p class="text-[11px] font-medium uppercase tracking-[0.12em] text-muted-foreground">AI Knowledge Hub</p>
							<h1 class="truncate text-sm font-semibold tracking-tight sm:text-base">{SITE_NAME}</h1>
						</div>
					</a>

					<ThemeToggle client:load />
				</div>
				<NavigationMenu className="overflow-x-auto border-t border-border px-3 py-2 lg:hidden">
					<NavigationMenuList className="flex-row gap-1">
						{STATIC_PAGES.map((item) => (
							<NavigationMenuItem>
								<NavigationMenuLink
									href={navUrl(item.href)}
									className={[
										'whitespace-nowrap px-2.5 py-1.5 text-xs font-medium',
										isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''
									].filter(Boolean).join(' ')}
								>
									{item.label}
								</NavigationMenuLink>
							</NavigationMenuItem>
						))}
					</NavigationMenuList>
				</NavigationMenu>
			</header>

			<div class="mx-auto grid w-full max-w-[1500px] grid-cols-1 gap-4 px-3 py-4 lg:grid-cols-[250px_minmax(0,1fr)] lg:px-5">
				<aside class="hidden lg:block">
					<Card className="sticky top-16">
						<ScrollArea className="max-h-[calc(100dvh-5rem)] p-2">
							<NavigationMenu>
								<div class="px-2 pb-2">
									<p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground">Navigation</p>
								</div>
								<NavigationMenuList>
									{CORE_PAGES.map((item) => (
										<NavigationMenuItem>
											<NavigationMenuLink
												href={navUrl(item.href)}
												className={isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''}
											>
												<span class="block font-medium">{item.label}</span>
												<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
											</NavigationMenuLink>
										</NavigationMenuItem>
									))}
								</NavigationMenuList>

								<div class="mt-3 border-t border-border pt-3">
									<p class="px-2 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">はじめに読む</p>
									<NavigationMenuList className="mt-2 gap-0.5">
										{GUIDE_PAGES.map((item) => (
											<NavigationMenuItem>
												<NavigationMenuLink
													href={navUrl(item.href)}
													className={['py-1.5', isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''].filter(Boolean).join(' ')}
												>
													<span class="block font-medium">{item.label}</span>
													<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
												</NavigationMenuLink>
											</NavigationMenuItem>
										))}
									</NavigationMenuList>
								</div>

								<div class="mt-3 border-t border-border pt-3">
									<p class="px-2 text-[11px] font-semibold tracking-[0.08em] text-muted-foreground">調べる・使う</p>
									<NavigationMenuList className="mt-2 gap-0.5">
										{REFERENCE_PAGES.map((item) => (
											<NavigationMenuItem>
												{item.children ? (
													<details
														class="group rounded-md"
														open={isActive(item.href) || item.children.some((group) => isActive(group.href) || group.children?.some((child) => isActive(child.href)))}
													>
														<summary
															class={[
																'flex cursor-pointer list-none items-start justify-between gap-2 rounded-md px-3 py-1.5 text-sm transition-colors hover:bg-accent hover:text-accent-foreground',
																isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''
															].filter(Boolean).join(' ')}
														>
															<a href={navUrl(item.href)} class="min-w-0 flex-1 text-inherit no-underline">
																<span class="block font-medium">{item.label}</span>
																<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
															</a>
															<span class="mt-1 text-xs text-muted-foreground transition-transform group-open:rotate-90">›</span>
														</summary>
														<div class="ml-3 mt-1 border-l border-border pl-2">
															{item.children.map((group) => (
																<div class="py-1">
																	<a href={navUrl(group.href)} class="block rounded-md px-2 py-1 text-xs font-semibold text-muted-foreground no-underline hover:bg-muted hover:text-foreground">
																		{group.label}
																	</a>
																	{group.children && (
																		<div class="mt-0.5 grid gap-0.5">
																			{group.children.map((child) => (
																				<a
																					href={navUrl(child.href)}
																					class={[
																						'block rounded-md px-2 py-1 text-xs text-muted-foreground no-underline hover:bg-muted hover:text-foreground',
																						isActive(child.href) ? 'bg-secondary text-foreground' : ''
																					].filter(Boolean).join(' ')}
																				>
																					{child.label}
																				</a>
																			))}
																		</div>
																	)}
																</div>
															))}
														</div>
													</details>
												) : (
													<NavigationMenuLink
														href={navUrl(item.href)}
														className={['py-1.5', isActive(item.href) ? 'bg-secondary text-secondary-foreground' : ''].filter(Boolean).join(' ')}
													>
														<span class="block font-medium">{item.label}</span>
														<span class="mt-0.5 block text-xs text-muted-foreground">{item.description}</span>
													</NavigationMenuLink>
												)}
											</NavigationMenuItem>
										))}
									</NavigationMenuList>
								</div>
							</NavigationMenu>
						</ScrollArea>
					</Card>
				</aside>

				<main class="min-w-0 pb-12">
					<slot />
				</main>
			</div>
		</div>
	</body>
</html>
