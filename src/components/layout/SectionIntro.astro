---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={['space-y-3', align === 'center' ? 'text-center' : 'text-left']}>
	{eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.18em] text-muted-foreground">{eyebrow}</p>}
	<h2 class="text-2xl font-semibold tracking-tight text-balance">{title}</h2>
	<p class="max-w-2xl text-base leading-8 text-muted-foreground">{description}</p>
</div>
