---
import type { CategorySummary } from '@/lib/content';
import { Badge } from '@/components/ui/badge';
import { Card, CardContent } from '@/components/ui/card';

interface Props {
  category: CategorySummary;
}

const { category } = Astro.props;
---

<a href={category.href} class="group block no-underline">
	<Card className="transition-colors hover:bg-muted">
		<CardContent className="p-5">
			<div class="flex items-start justify-between gap-4">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.16em] text-muted-foreground">{category.name}</p>
					<h3 class="mt-3 text-xl font-semibold tracking-tight text-foreground">{category.count}件の記事</h3>
				</div>
				<span class="flex h-10 w-10 items-center justify-center rounded-md border border-border bg-secondary text-base font-semibold text-primary">
					{category.name.slice(0, 1)}
				</span>
			</div>
			<p class="mt-4 text-sm leading-7 text-muted-foreground">{category.description}</p>
			<div class="mt-5 flex flex-wrap gap-2">
				{category.tags.map((tag) => (
					<Badge variant="outline">#{tag}</Badge>
				))}
			</div>
		</CardContent>
	</Card>
</a>
